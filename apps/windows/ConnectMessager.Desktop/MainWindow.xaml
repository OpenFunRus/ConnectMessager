<Window x:Class="ConnectMessager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="ConnectMessager"
        Width="1440"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Background="#0B1117"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <wv2:WebView2 x:Name="Browser" />

        <Border x:Name="Overlay"
                Background="#E60B1117"
                Panel.ZIndex="10">
            <Grid>
                <Border Width="560"
                        Padding="36"
                        CornerRadius="20"
                        Background="#111A24"
                        BorderBrush="#253447"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="OverlayTitleTextBlock"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="#F3F7FC"
                                   TextAlignment="Center"
                                   Text="Запуск ConnectMessager" />
                        <TextBlock x:Name="OverlayBodyTextBlock"
                                   Margin="0,14,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="#9AB0C3"
                                   FontSize="14"
                                   Text="Подготавливаем приложение и загружаем сайт." />
                        <TextBlock x:Name="OverlayCountdownTextBlock"
                                   Margin="0,16,0,0"
                                   Foreground="#6DA8FF"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   TextAlignment="Center"
                                   Visibility="Collapsed"
                                   Text="Переподключение через 60 секунд..." />
                        <Button x:Name="RetryButton"
                                Width="170"
                                Margin="0,22,0,0"
                                Padding="14,10"
                                HorizontalAlignment="Center"
                                Click="RetryButton_OnClick"
                                Visibility="Collapsed"
                                Content="Обновить" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
